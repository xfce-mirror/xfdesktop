#: ../settings/main.c:771
msgid ""
"Move this dialog to the display and workspace you want to edit the settings "
"for."
msgstr ""
"ຍ້າຍກ່ອງຂໍ້ຄວາມນີ້ໄປຍັງຈໍພາບ ແລະ "
"ພື້ນທີ່ເຮັດວຽກທີ່ເຈົ້າຕ້ອງການແກ້ໄຂການຕັ້ງຄ່າ."

#. Single monitor and single workspace
#: ../settings/main.c:779
#, c-format
msgid "Wallpaper for my desktop"
msgstr "ຮູບພື້ນຫຼັງສຳລັບໜ້າຈໍຂອງຂ້ອຍ"

#. Single monitor and per workspace wallpaper
#: ../settings/main.c:785
#, c-format
msgid "Wallpaper for %s"
msgstr "ຮູບພື້ນຫຼັງສຳລັບ %s"

#: ../settings/main.c:790
msgid "Move this dialog to the workspace you want to edit the settings for."
msgstr "ຍ້າຍກ່ອງຂໍ້ຄວາມນີ້ໄປຍັງພື້ນທີ່ເຮັດວຽກທີ່ເຈົ້າຕ້ອງການແກ້ໄຂການຕັ້ງຄ່າ."

#: ../settings/main.c:1243
msgid "Image selection is unavailable while the image style is set to None."
msgstr "ການເລືອກຮູບພາບບໍ່ສາມາດໃຊ້ໄດ້ໃນຂະນະທີ່ຮູບແບບຮູບພາບຖືກຕັ້ງເປັນ ບໍ່ມີ."

#: ../settings/main.c:1603
msgid "Spanning screens"
msgstr "ເຕັມທຸກໜ້າຈໍ"

