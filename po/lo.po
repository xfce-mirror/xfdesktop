#: ../settings/xfce-backdrop-settings.desktop.in.in.h:2
msgid "Set desktop background and menu and icon behavior"
msgstr "ຕັ້ງຄ່າພື້ນຫຼັງໜ້າຈໍ, ເມນູ ແລະ ພຶດຕິກຳໄອຄອນ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:1
msgid "Solid color"
msgstr "ສີລ້ວນ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:2
msgid "Horizontal gradient"
msgstr "ໄລ່ສີແນວນອນ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:3
msgid "Vertical gradient"
msgstr "ໄລ່ສີແນວຕັ້ງ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:4
msgid "Transparent"
msgstr "ໂປ່ງໃສ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:5
msgid "Choose the folder to select wallpapers from."
msgstr "ເລືອກໂຟນເດີເພື່ອເລືອກຮູບພື້ນຫຼັງ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:6
msgid "Apply"
msgstr "ນຳໃຊ້"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:7
msgid "St_yle:"
msgstr "ຮູບແບບ(_Y):"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:8
msgid "Specify how the image will be resized to fit the screen."
msgstr "ກຳນົດວິທີການປັບຂະໜາດຮູບພາບໃຫ້ພໍດີກັບໜ້າຈໍ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:9
#: ../settings/xfdesktop-settings-ui.glade.h:4
msgid "None"
msgstr "ບໍ່ມີ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:10
msgid "Centered"
msgstr "ໄວ້ກາງ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:11
msgid "Tiled"
msgstr "ຮຽງຕໍ່ກັນ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:12
msgid "Stretched"
msgstr "ຢືດ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:13
msgid "Scaled"
msgstr "ປັບຂະໜາດ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:14
msgid "Zoomed"
msgstr "ຊູມ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:15
msgid "Spanning Screens"
msgstr "ຂະຫຍາຍເຕັມທຸກໜ້າຈໍ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:16
msgid "Specify the style of the color drawn behind the backdrop image."
msgstr "ກຳນົດຮູບແບບຂອງສີທີ່ຈະສະແດງຢູ່ທາງຫຼັງຮູບພື້ນຫຼັງ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:17
msgid "Specifies the solid color, or the \"left\" or \"top\" color of the gradient."
msgstr "ກຳນົດສີລ້ວນ, ຫຼື ສີ \"ເບື້ອງຊ້າຍ\" ຫຼື \"ເບື້ອງເທິງ\" ຂອງການໄລ່ສີ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:18
msgid "Select First Color"
msgstr "ເລືອກສີທຳອິດ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:19
msgid "Specifies the \"right\" or \"bottom\" color of the gradient."
msgstr "ກຳນົດສີ \"ເບື້ອງຂວາ\" ຫຼື \"ເບື້ອງລຸ່ມ\" ຂອງການໄລ່ສີ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:20
msgid "Select Second Color"
msgstr "ເລືອກສີທີສອງ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:21
msgid "Apply to all _workspaces"
msgstr "ນຳໃຊ້ກັບທຸກພື້ນທີ່ເຮັດວຽກ(_W)"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:22
msgid "_Folder:"
msgstr "ໂຟນເດີ(_F):"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:23
msgid "C_olor:"
msgstr "ສີ(_O):"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:24
msgid "Change the _background "
msgstr "ປ່ຽນພື້ນຫຼັງ(_B)"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:25
msgid ""
"Automatically select a different background from the current directory."
msgstr "ເລືອກຮູບພື້ນຫຼັງອື່ນຈາກໄດເຣັກທໍຣີປັດຈຸບັນໂດຍອັດຕະໂນມັດ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:26
msgid "Specify how often the background will change."
msgstr "ກຳນົດວ່າຈະໃຫ້ປ່ຽນພື້ນຫຼັງເລື້ອຍປານໃດ."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:27
msgid "in seconds:"
msgstr "ເປັນວິນາທີ:"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:28
msgid "in minutes:"
msgstr "ເປັນນາທີ:"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:29
msgid "in hours:"
msgstr "ເປັນຊົ່ວໂມງ:"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:30
msgid "at start up"
msgstr "ເມື່ອເລີ່ມຕົ້ນລະບົບ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:31
msgid "every hour"
msgstr "ທຸກໆຊົ່ວໂມງ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:32
msgid "every day"
msgstr "ທຸກໆມື້"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:33
msgid "chronologically"
msgstr "ຕາມລຳດັບເວລາ"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:34
msgid "Amount of time before a different background is selected."
msgstr "ໄລຍະເວລາກ່ອນທີ່ຈະເລືອກພື້ນຫຼັງໃໝ່."

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:35
msgid "_Random Order"
msgstr "ແບບສຸ່ມ(_R)"

#: ../settings/xfdesktop-settings-appearance-frame-ui.glade.h:36
msgid ""
"Randomly selects another image from the same directory when the wallpaper is"
" to cycle."
msgstr "ສຸ່ມເລືອກຮູບພາບອື່ນຈາກໄດເຣັກທໍຣີດຽວກັນເມື່ອຮູບພື້ນຫຼັງໝູນວຽນ."

